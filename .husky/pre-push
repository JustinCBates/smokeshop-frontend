#!/usr/bin/env sh
set -e

should_run=0

while read -r local_ref local_sha remote_ref remote_sha
do
  if [ "$remote_ref" = "refs/heads/development" ] || [ "$local_ref" = "refs/heads/development" ]; then
    should_run=1
  fi
done

if [ "$should_run" -ne 1 ]; then
  echo "Skipping CI rig: push is not targeting development."
  exit 0
fi

echo "Running CI rig before push to development..."

if command -v corepack >/dev/null 2>&1; then
  corepack pnpm run ci:rig
elif command -v pnpm >/dev/null 2>&1; then
  pnpm run ci:rig
else
  npm run ci:rig
fi
