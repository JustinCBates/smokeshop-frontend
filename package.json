{
  "name": "generic-smokeshop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "node server.js",
    "start:next": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "vitest --passWithNoTests",
    "test:watch": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "type-check": "tsc --noEmit",
    "check-all": "npm run lint && npm run type-check && npm run test:ci",
    "ci:rig": "npm run lint && npm run type-check && npm run test:ci && npm run build",
    "migrate": "node scripts/run-migrations.js",
    "setup": "node scripts/run-migrations.js && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "latest",
    "@turf/boolean-point-in-polygon": "latest",
    "@turf/helpers": "latest",
    "@types/leaflet": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "leaflet": "latest",
    "lucide-react": "latest",
    "next": "^15",
    "pg": "^8.11.3",
    "react": "^19",
    "react-dom": "^19",
    "react-leaflet": "latest",
    "server-only": "latest",
    "swagger-ui-react": "^5.17.14",
    "swr": "latest",
    "tailwind-merge": "latest",
    "tailwindcss": "^3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/pg": "^8.11.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "^15",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "postcss": "^8",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
