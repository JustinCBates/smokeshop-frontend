# PostgreSQL Database (VPS Self-Hosted)
# Connection string for products, inventory, and regional data
DATABASE_URL=postgresql://smokeshop_user:your_password@your_vps_ip:5432/smokeshop

# Coinbase Commerce (Crypto Payments)
COINBASE_COMMERCE_API_KEY=your_coinbase_commerce_api_key
COINBASE_COMMERCE_WEBHOOK_SECRET=your_webhook_secret_optional

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Age Verification Provider (optional)
AGE_VERIFICATION_PROVIDER=dob-photo

# Inventory manager access control (server-side)
# Comma-separated list of manager emails allowed to call /api/admin/inventory/*
INVENTORY_MANAGER_EMAILS=manager@example.com,owner@example.com

# Clover OAuth and API (production defaults)
CLOVER_APP_ID=your_clover_app_id
CLOVER_APP_SECRET=your_clover_app_secret
CLOVER_ACCESS_TOKEN=your_clover_access_token
CLOVER_MERCHANT_ID=your_clover_merchant_id
CLOVER_WEBHOOK_SECRET=your_clover_webhook_secret_optional
# Optional override. Defaults to https://www.clover.com
CLOVER_OAUTH_BASE_URL=https://www.clover.com
# Optional override. Defaults to https://api.clover.com
CLOVER_API_BASE_URL=https://api.clover.com
# Optional override. Defaults to https://yourdomain.com/api/auth/clover/callback
CLOVER_REDIRECT_URI=https://yourdomain.com/api/auth/clover/callback
