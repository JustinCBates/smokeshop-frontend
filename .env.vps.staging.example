NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

NEXT_PUBLIC_SITE_URL=https://staging.neutraldevelopment.com
AGE_VERIFICATION_PROVIDER=dob-photo

# Required by app runtime
DATABASE_URL=postgresql://smokeshop_user:CHANGE_ME@host.docker.internal:5432/smokeshop

# Transitional auth variables (required by current app code paths)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: comma-separated manager emails
INVENTORY_MANAGER_EMAILS=

# Clover
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_ACCESS_TOKEN=
CLOVER_MERCHANT_ID=
CLOVER_WEBHOOK_SECRET=
CLOVER_OAUTH_BASE_URL=https://www.clover.com
CLOVER_API_BASE_URL=https://api.clover.com
CLOVER_REDIRECT_URI=https://staging.neutraldevelopment.com/api/auth/clover/callback
